@inherits LayoutComponentBase
<div class="page">
    <main>
        <div class="brand-header">
            <div class="logo-container">
                <div class="logo-icon">
                    <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="bg-grad" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#534AB7"/>
                        <stop offset="100%" stop-color="#3C3489"/>
                        </linearGradient>
                    </defs>

                    <rect width="120" height="120" rx="28" fill="url(#bg-grad)"/>
                    <rect x="24" y="58" width="72" height="42" rx="7" fill="#EEEDFE" opacity="0.95"/>
                    <rect x="18" y="48" width="84" height="16" rx="6" fill="#CECBF6"/>
                    <rect x="46" y="54" width="28" height="5" rx="2.5" fill="#534AB7"/>
                    <rect x="46" y="30" width="28" height="20" rx="4" fill="white" opacity="0.95"/>
                    <rect x="51" y="36" width="10" height="2.5" rx="1" fill="#AFA9EC"/>
                    <rect x="51" y="41" width="14" height="2.5" rx="1" fill="#AFA9EC"/>
                    <circle cx="68" cy="33" r="8" fill="#1D9E75"/>
                    <path d="M63.5 33.5 L66.5 36.5 L73 30" stroke="white" stroke-width="2"
                            fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="brand-name">Votify</span>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
<style>
    .brand-header {
    display: flex;
    justify-content: center;
    padding: 1.5rem 0;
    margin-bottom: 0px;
}

.logo-container {
    display: flex;
    align-items: center;
    gap: 0.6rem;
}

.logo-icon svg {
    width: 40px;
    height: 40px;
}

.brand-name {
    font-size: 1.6rem;
    font-weight: 800;
    color: #4c1d95; 
    letter-spacing: -0.03em;
    font-family: 'Inter', sans-serif;
}
</style>
